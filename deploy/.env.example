# SecuGent — production environment template.
#
# Copy to `.env` and set REAL values before booting the production stack:
#   cp .env.example .env  &&  $EDITOR .env
#   docker compose --env-file .env up -d
#
# NOTE: production Vault starts sealed; secugent-api waits until you run the
# one-time `vault operator init` + `unseal` (see deploy/docker-compose.yml
# header / deploy/vault/vault.hcl runbook). The stack does not fully come up
# until Vault is unsealed.
#
# Every variable below is REQUIRED. The production compose fails closed
# (refuses to start) if any of these is unset. The placeholder values here are
# NOT valid secrets — replace each one. Do NOT commit your real .env (it is
# gitignored, but never force-add it).

# Postgres password for the `secugent` role (event store). Use a strong, unique value.
POSTGRES_PASSWORD=change-me-strong-db-password

# Address of the HashiCorp Vault KV v2 backend reachable from the api container.
VAULT_ADDR=http://vault:8200

# Vault token with read access to SecuGent's KV mount. Issue a scoped, renewable token.
VAULT_TOKEN=change-me-vault-token

# Anthropic API key for BYO-Model planning/risk analysis (live LLM calls).
ANTHROPIC_API_KEY=change-me-anthropic-api-key

# Grafana admin password (initial login for the monitoring UI on :3000).
GRAFANA_PASSWORD=change-me-grafana-admin-password
