# Misconfigured production deploy snapshot (preflight fixture).
# Reproduces multiple documented blockers at once so `secugent verify --deploy`
# fails clearly with critical + high findings.

# production but KMS provider left at the dev HMAC default (provider=local
# with require_external auto-True) → boot would crash. (critical)
SECUGENT_ENV=production
SECUGENT_KMS_PROVIDER=local

# no DATABASE_URL and no SECUGENT_DB_PATH → audit chain risks ephemeral
# storage. (high)  [SECUGENT_DB_PATH intentionally absent]

# HA turned on without a shared Postgres → forked audit chain. (high)
SECUGENT_HA_ENABLED=1

# no Anthropic key, a sovereign endpoint set, but no model id. (high)
SECUGENT_DOMESTIC_MODEL_ENDPOINT=https://sovereign-llm.internal:8080

# LDAP auth over plaintext ldap:// without an explicit insecure opt-in. (high)
SECUGENT_AUTH_MODE=ldap
SECUGENT_LDAP_URI=ldap://ad.corp.internal:389

# egress broker on (prod default) with no signed policy bundle / key pin. (high)
# [SECUGENT_POLICY_BUNDLE_PATH and SECUGENT_POLICY_ALLOWED_KEY_IDS intentionally absent]

# no sandbox roots and no allowed domains → built-in tools disabled. (info)
