# A correctly-configured production deploy snapshot (B1 preflight fixture).
# Every critical/high check passes → `secugent verify --deploy` exits 0.

SECUGENT_ENV=production

# A1 — external KMS selected (not the dev HMAC).
SECUGENT_KMS_PROVIDER=vault_transit
VAULT_ADDR=https://vault.corp.internal:8200
VAULT_TOKEN=s.example-token

# W6-A / W6-B — shared Postgres + a mounted durable SQLite path.
DATABASE_URL=postgresql+asyncpg://secugent:pw@pg.corp.internal:5432/secugent
SECUGENT_DB_PATH=/data/secugent/secugent.db

# W6-LLM — a real model key is configured.
ANTHROPIC_API_KEY=sk-ant-example-000

# B6 — egress broker fed a signed, key-pinned policy bundle.
SECUGENT_POLICY_BUNDLE_PATH=/etc/secugent/policy.bundle.json
SECUGENT_POLICY_ALLOWED_KEY_IDS=merkle-2026-01

# W6-H — built-in tool surface enabled.
SECUGENT_SANDBOX_ROOTS=/srv/secugent/work
SECUGENT_ALLOWED_DOMAINS=api.corp.internal
